  "fixed_sql": [
    {
      "name": "course",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"course\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"search_key\" TEXT NOT NULL GENERATED ALWAYS AS (createSearchKey(\"name\", \"id\")) STORED, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "semester",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"semester\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL);"
        }
      ]
    },
    {
      "name": "course_class",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"course_class\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"class_code\" TEXT NOT NULL, \"day_of_week\" INTEGER NULL, \"from_period\" INTEGER NULL, \"to_period\" INTEGER NULL, \"location\" TEXT NULL, \"course_id\" TEXT NOT NULL REFERENCES course (id) ON UPDATE CASCADE ON DELETE RESTRICT, \"semester_id\" INTEGER NOT NULL REFERENCES semester (id) ON UPDATE CASCADE ON DELETE RESTRICT);"
        }
      ]
    },
    {
      "name": "session",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"session\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"course_class_id\" INTEGER NOT NULL REFERENCES course_class (id) ON UPDATE CASCADE ON DELETE CASCADE, \"date\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "student",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"student\" (\"id\" TEXT NOT NULL, \"email\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"sort_key\" TEXT NOT NULL GENERATED ALWAYS AS (getFirstName(\"name\")) STORED, \"search_key\" TEXT NOT NULL GENERATED ALWAYS AS (createSearchKey(\"name\", \"id\")) STORED, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "attendance",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"attendance\" (\"attendance_status\" TEXT NOT NULL, \"num_contributions\" INTEGER NOT NULL DEFAULT 0, \"session_id\" INTEGER NOT NULL REFERENCES session (id) ON UPDATE CASCADE ON DELETE CASCADE, \"student_id\" TEXT NOT NULL REFERENCES student (id) ON UPDATE CASCADE ON DELETE CASCADE, PRIMARY KEY (\"session_id\", \"student_id\"));"
        }
      ]
    },
    {
      "name": "registration",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"registration\" (\"course_class_id\" INTEGER NOT NULL REFERENCES course_class (id) ON UPDATE CASCADE ON DELETE CASCADE, \"student_id\" TEXT NOT NULL REFERENCES student (id) ON UPDATE CASCADE ON DELETE CASCADE, PRIMARY KEY (\"course_class_id\", \"student_id\"));"
        }
      ]
    }
  ]
